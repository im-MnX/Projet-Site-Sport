{% extends 'base.html.twig' %}

{% block title %}Résultats{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Résultats</h1>

    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-md);">
        {% for resultat in resultats %}
            <h2>{{ resultat.titre }}</h2>
            <div style="margin-bottom: 20px;">
                {{ resultat.contenu|raw }}
            </div>
        {% else %}
            <p style="color: var(--text-muted); text-align: center; padding: 2rem;">Aucun résultat disponible pour le moment.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
