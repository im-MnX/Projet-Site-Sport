{% extends 'base.html.twig' %}

{% block title %}Résultats{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/resultats.css') }}">
{% endblock %}

{% block body %}
<div class="page-container">

    <header class="resultats-header">
        <h1>Résultats</h1>
        <span class="resultats-subtitle">Compétitions &amp; palmarès</span>
    </header>

    <div class="resultats-list">
        {% for resultat in resultats %}
            <div class="resultat-section">
                <h2>
                    <span class="resultat-num">{{ loop.index }}</span>
                    {{ resultat.titre }}
                </h2>
                {{ resultat.contenu|raw }}
            </div>
        {% else %}
            <p class="resultats-empty"><i class="fa-solid fa-trophy"></i> Aucun résultat disponible pour le moment.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}
