{% extends 'admin_base.html.twig' %}

{% block title %}Gestion des Albums{% endblock %}

{% block page_title %}Albums{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Liste des Albums</h2>
            <a href="{{ path('app_admin_album_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Nouvel Album
            </a>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Priorité</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for album in albums %}
                    <tr>
                        <td>
                            <div style="font-weight: 600; color: var(--text-color);">{{ album.description }}</div>
                        </td>
                        <td>
                            <span class="badge" style="background-color: #f1f5f9; color: var(--text-muted); border: 1px solid var(--border-color);">
                                <i class="fa-solid fa-arrow-up-9-1"></i> {{ album.priorite }}
                            </span>
                        </td>
                        <td>
                            {% if album.archive %}
                                <span class="badge" style="background-color: #fee2e2; color: #991b1b; border: 1px solid #fecaca; padding: 0.4rem 0.8rem;">
                                    <i class="fa-solid fa-box-archive"></i> Archivé
                                </span>
                            {% else %}
                                <span class="badge" style="background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; padding: 0.4rem 0.8rem;">
                                    <i class="fa-solid fa-circle-check"></i> Actif
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="{{ path('app_admin_album_show', {'idAlbum': album.idAlbum}) }}" class="btn btn-sm btn-info" title="Voir">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="{{ path('app_admin_album_edit', {'idAlbum': album.idAlbum}) }}" class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem;">
                            <div style="color: var(--text-muted); margin-bottom: 1rem;">
                                <i class="fa-regular fa-images" style="font-size: 2rem;"></i>
                                <p style="margin-top: 0.5rem;">Aucun album trouvé</p>
                            </div>
                            <a href="{{ path('app_admin_album_new') }}" class="btn btn-primary">
                                <i class="fa-solid fa-plus"></i> Créer un album
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
