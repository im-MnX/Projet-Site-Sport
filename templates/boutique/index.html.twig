{% extends 'base.html.twig' %}

{% block title %}Boutique{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/boutique.css') }}?v={{ 'now'|date('U') }}">
{% endblock %}

{% block body %}
<div class="page-container">

    <header class="boutique-header">
        <h1>La Boutique du Club</h1>
        <span class="boutique-subtitle">Articles &amp; équipements</span>
    </header>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        {% for produit in produits %}
            <div class="col">
                <a href="{{ produit.lien }}" class="product-card-link h-100" target="_blank">
                    <article class="product-card h-100">
                        <div class="product-image-wrapper">
                            {% if produit.image %}
                                <img src="{{ asset('uploads/produits/' ~ produit.image) }}" alt="{{ produit.nomProduit }}">
                            {% else %}
                                <div class="product-placeholder">
                                    <i class="fas fa-shopping-bag"></i>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="product-info">
                            <h2 class="product-title">{{ produit.nomProduit }}</h2>
                            <p class="product-desc">{{ produit.description }}</p>
                            
                            <div class="product-footer">
                                <span class="product-price">{{ produit.prix|number_format(2, ',', ' ') }} €</span>
                            </div>
                        </div>
                    </article>
                </a>
            </div>
        {% else %}
            <div class="col-12">
                <div class="empty-shop">
                    <i class="fas fa-store-slash" style="font-size: 3rem; margin-bottom: 20px; color: #ccc;"></i>
                    <h3>Aucun produit disponible pour le moment</h3>
                    <p>Revenez bientôt pour découvrir notre nouvelle collection !</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
