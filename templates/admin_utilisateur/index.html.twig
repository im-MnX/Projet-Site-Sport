{% extends 'admin_base.html.twig' %}
{% block title %}Gestion des Utilisateurs{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}
{% block body %}
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Liste des Utilisateurs</h2>
        <a href="{{ path('app_admin_utilisateur_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvel Utilisateur</a>
    </div>
    <div class="table-responsive">
        <table class="table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for utilisateur in utilisateurs %}
                    <tr>
                        <td>
                            <div style="font-weight: 600; color: var(--text-color);">{{ utilisateur.email }}</div>
                        </td>
                        <td>
                            {% for role in utilisateur.roles %}
                                <span class="badge" style="background-color: #f1f5f9; color: var(--text-muted); border: 1px solid var(--border-color); margin-right: 0.25rem; padding: 0.3rem 0.6rem;">
                                    {{ role }}
                                </span>
                            {% endfor %}
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="{{ path('app_admin_utilisateur_show', {'idUtilisateur': utilisateur.idUtilisateur}) }}" class="btn btn-sm btn-info" title="Voir">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="{{ path('app_admin_utilisateur_edit', {'idUtilisateur': utilisateur.idUtilisateur}) }}" class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form method="post" action="{{ path('app_admin_utilisateur_delete', {'idUtilisateur': utilisateur.idUtilisateur}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');" style="display: inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.idUtilisateur) }}">
                                    <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                <tr>
                    <td colspan="3" style="text-align: center; padding: 2rem;">
                        <div style="color: var(--text-muted); margin-bottom: 1rem;">
                            <i class="fa-regular fa-user" style="font-size: 2rem;"></i>
                            <p style="margin-top: 0.5rem;">Aucun utilisateur trouvé</p>
                        </div>
                        <a href="{{ path('app_admin_utilisateur_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Ajouter un utilisateur</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
