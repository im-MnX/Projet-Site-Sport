{% extends 'admin_base.html.twig' %}
{% block title %}Détails de la Section{% endblock %}
{% block page_title %}Détails de la Section{% endblock %}
{% block breadcrumb %}<span>Administration</span> / <a href="{{ path('app_admin_about_index') }}">Présentation</a> / <span>Détails</span>{% endblock %}
{% block body %}
<div class="card" style="max-width: 800px; margin: 0 auto;">
    <div class="card-header">
        <h2 class="card-title">{{ about.titre }}</h2>
        <div style="display: flex; gap: 0.5rem;">
            <a href="{{ path('app_admin_about_index') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a>
            <a href="{{ path('app_admin_about_edit', {'id': about.idAbout}) }}" class="btn btn-warning"><i class="fa-solid fa-pen"></i> Modifier</a>
            {{ include('admin_about/_delete_form.html.twig') }}
        </div>
    </div>
    <div style="padding: 1.5rem;">
        <table class="table">
            <tbody>
                <tr><th style="width: 30%;">Titre</th><td>{{ about.titre }}</td></tr>
                <tr><th>Contenu</th><td>{{ about.contenu|raw }}</td></tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
