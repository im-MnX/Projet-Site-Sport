{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/inscription.css') }}">
{% endblock %}

{% block body %}
    <div class="page-container">
        <h1>Inscriptions</h1>

        {% if inscription %}
        <div class="inscription-wrapper">
            
            <!-- Section 1 : Permanences & HelloAsso -->
            <div class="permanences-section">
                <div class="permanences-info">
                    <h2>Des permanences auront lieu au club :</h2>
                    <div class="permanences-list">
                        {{ inscription.permanencesTexte|raw }}
                    </div>
                </div>
                
                {% if inscription.lienHelloasso %}
                <a href="{{ inscription.lienHelloasso }}"
                    class="btn-helloasso"
                    target="_blank"
                    rel="noopener noreferrer">
                    Inscription par HelloAsso
                </a>
                {% endif %}
            </div>

            <!-- Section 2 : Préparation & Documents -->
            <div class="preparation-section">
                <div class="prep-card">
                    <i class="fas fa-lightbulb bulb-icon"></i>
                    <span>PREPARATION</span>
                </div>

                <div class="documents-list">
                    <a href="{{ asset(get_document_path('FICHE_INSCRIPTION')|default('FichiersInscription/Feuille-inscription.docx')) }}" class="doc-link" target="_blank">Fiche d'inscription</a>
                    <a href="{{ asset(get_document_path('FEUILLE_URGENCE')|default('FichiersInscription/Feuille-urgence.pdf')) }}" class="doc-link" target="_blank">Feuille d'urgence</a>
                    <a href="{{ asset(get_document_path('MOYEN_PAIEMENT')|default('FichiersInscription/Feuille-inscription-comptabilite.docx')) }}" class="doc-link" target="_blank">Moyen de paiement</a>
                    <br> <!-- Spacer -->
                    <a href="{{ asset(get_document_path('FORMULAIRE_LICENCE_FFN')|default('FichiersInscription/Formulairelicencemineur20252026remplissable.pdf')) }}" class="doc-link" target="_blank">Formulaire licence FFN-Mineur</a>
                    <a href="https://www.ffnatation.fr/sites/default/files/2025-09/Re%CC%80glements%20NA%202025-2026-vers%200825.pdf" class="doc-link" target="_blank">Règlement FFN</a>
                </div>
            </div>

            <!-- Section 3 : Contact -->
            <div class="contact-section-inscription">
                <div class="contact-person">
                    <div class="contact-avatar" style="display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #fff; background: #bbb;">
                        <img src="{{ asset(inscription.contactPhoto ?? 'images/RachelLeBozec.jpg') }}" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover; border-radius: 10px;">
                    </div>
                    <strong>{{ inscription.contactNom ?? 'Contact' }}</strong>
                </div>
                
                <div class="contact-details">
                    <p>{{ inscription.contactTexte ?? 'Pour toutes nouvelles inscriptions, contactez le secrétariat par mail' }}</p>
                    {% if inscription.contactEmail %}
                    <p>(<a href="mailto:{{ inscription.contactEmail }}">{{ inscription.contactEmail }}</a>).</p>
                    {% endif %}
                </div>
            </div>

        </div>
        {% else %}
        <div class="inscription-wrapper">
            <p style="text-align: center; color: var(--text-muted); padding: 3rem 0;">
                <i class="fas fa-tools" style="font-size: 2rem; margin-bottom: 1rem; display: block;"></i>
                Le contenu de cette page est en cours de configuration. Revenez bientôt !
            </p>
        </div>
        {% endif %}
    </div>
{% endblock %}

