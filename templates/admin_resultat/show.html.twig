{% extends 'admin_base.html.twig' %}
{% block title %}Détails du Résultat{% endblock %}
{% block page_title %}Aperçu du résultat{% endblock %}
{% block body %}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="card-title">{{ resultat.titre }}</h2>
        <div class="d-flex gap-2">
            <a href="{{ path('app_admin_resultat_edit', {'id': resultat.idResultat}) }}" class="btn btn-warning">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            {{ include('admin_resultat/_delete_form.html.twig') }}
        </div>
    </div>
    <div class="card-body">
        <div class="resultat-preview" style="background: var(--bg-light); padding: 2rem; border-radius: 8px;">
            {{ resultat.contenu|raw }}
        </div>
        
        <div class="mt-4 pt-4 border-top">
            <a href="{{ path('app_admin_resultat_index') }}" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>
</div>
{% endblock %}
