<form method="post" action="{{ path('app_admin_resultat_delete', {'id': resultat.idResultat}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ resultat.idResultat) }}">
    <button class="btn btn-outline-danger">
        <i class="fa-solid fa-trash-can"></i> Supprimer
    </button>
</form>
