{% extends 'base.html.twig' %}

{% block title %}Actualités
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/actualites.css') }}">
{% endblock %}




{% block body %}
	<div class="actualite-show-container">
        <h2>{{ actualite.titre }}</h2>
        <div class="card-date" style="text-align: center; margin-bottom: 30px; display: block;">Publié le {{ actualite.date ? actualite.date|date('d/m/Y') : '' }}</div>
        
        {% if actualite.images %}
            <img src="{{ asset('uploads/actualites/' ~ actualite.images) }}" alt="{{ actualite.titre }}" class="actualite-image">
        {% endif %}
        
        <div class="actualite-content">
            {{ actualite.description|raw }}
        </div>

        <div style="margin-top: 50px; text-align: center;">
            <a href="{{ path('app_actualites') }}" class="btn-back">
                <i class="fas fa-arrow-left"></i> Retour aux actualités
            </a>
        </div>
	</div>
{% endblock %}
