{% extends 'base.html.twig' %}

{% block title %}Présentation du club{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/about.css') }}">
{% endblock %}

{% block body %}
<div class="page-container">

    <header class="about-header">
        <h1>Présentation du club</h1>
        <span class="about-subtitle">Angers Natation Synchronisée</span>
    </header>

    <div class="about-list">
        {% for about in abouts %}
            <div class="about-section">
                <h2>{{ about.titre }}</h2>
                {{ about.contenu|raw }}
            </div>
        {% else %}
            <p class="about-empty">Aucun contenu disponible pour le moment.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}
