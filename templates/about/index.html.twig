{% extends 'base.html.twig' %}

{% block title %}Présentation du club{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Présentation du club</h1>

    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-md);">
        {% for about in abouts %}
            <h2>{{ about.titre }}</h2>
            <div style="margin-bottom: 20px;">
                {{ about.contenu|raw }}
            </div>
        {% else %}
            <p style="color: var(--text-muted); text-align: center; padding: 2rem;">Aucun contenu disponible pour le moment.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
