{% extends 'admin_base.html.twig' %}
{% block title %}Gestion des Événements{% endblock %}
{% block page_title %}Événements{% endblock %}
{% block body %}
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Liste des Événements</h2>
        <a href="{{ path('app_admin_evenement_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvel Événement</a>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Nom</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Horaire</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for evenement in evenements %}
                <tr>
                    <td style="width: 80px;">
                        {% if evenement.images %}
                            <img src="{{ asset('uploads/evenements/' ~ evenement.images) }}" alt="{{ evenement.nom }}" style="width: 55px; height: 55px; object-fit: cover; border-radius: 10px; border: 1px solid var(--border-color);">
                        {% else %}
                            <span class="badge bg-secondary" style="font-size: 0.7rem; opacity: 0.7;">Aucune</span>
                        {% endif %}
                    </td>
                    <td>
                        <div style="font-weight: 600; color: var(--text-color);">{{ evenement.nom }}</div>
                        <div style="font-size: 0.85rem; color: var(--text-muted); max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            {{ evenement.description|striptags }}
                        </div>
                    </td>
                    <td>
                        {% if evenement.typeEvenement %}
                            <span class="badge" style="background-color: var(--bg-pale); color: var(--primary-color); border: 1px solid rgba(0, 153, 204, 0.2);">
                                {{ evenement.typeEvenement.libelleTypeEvenement }}
                            </span>
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td style="color: var(--text-muted); font-size: 0.9rem;">
                        {% if evenement.dateDebut == evenement.dateFin %}
                            {{ evenement.dateDebut|date('d/m/Y') }}
                        {% else %}
                            {{ evenement.dateDebut|date('d/m') }} - {{ evenement.dateFin|date('d/m/Y') }}
                        {% endif %}
                    </td>
                    <td style="color: var(--text-muted); font-size: 0.9rem;">{{ evenement.horaire ? evenement.horaire|date('H:i') : '-' }}</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="{{ path('app_admin_evenement_show', {'id': evenement.idEvenement}) }}" class="btn btn-sm btn-info" title="Voir"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_admin_evenement_edit', {'id': evenement.idEvenement}) }}" class="btn btn-sm btn-warning" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                            <form method="post" action="{{ path('app_admin_evenement_delete', {'id': evenement.idEvenement}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');" style="display: inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.idEvenement) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 2rem;">
                        <div style="color: var(--text-muted); margin-bottom: 1rem;">
                            <i class="fa-regular fa-calendar" style="font-size: 2rem;"></i>
                            <p style="margin-top: 0.5rem;">Aucun événement trouvé</p>
                        </div>
                        <a href="{{ path('app_admin_evenement_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Créer un événement</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
