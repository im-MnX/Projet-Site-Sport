<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}{% endblock %}
		</title>
		
		<link rel="icon" type="image/png" href="{{ asset('images/Logo_60ans.png') }}">

		{% block stylesheets %}
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
		{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}

		{% endblock %}
	</head>
	<body>
		<header class="site-header d-none d-xl-block">
			<nav class="site-nav" role="navigation" aria-label="Main navigation">
				<div class="nav-group-left">
					<div class="nav-social-group">
						<a class="nav-social-btn nav-social-fb" href="https://www.facebook.com/angers.nat.synchro" target="_blank" title="Facebook" aria-label="Facebook">
							<i class="fab fa-facebook-f"></i>
						</a>
						<a class="nav-social-btn nav-social-ig" href="https://www.instagram.com/angers_nat_synchro/" target="_blank" title="Instagram" aria-label="Instagram">
							<i class="fab fa-instagram"></i>
						</a>
						<a class="nav-social-btn nav-social-tt" href="https://www.tiktok.com/@angersnatsynchro" target="_blank" title="TikTok" aria-label="TikTok">
							<i class="bi bi-tiktok"></i>
						</a>
					</div>
					<div class="site-dropdown" data-dropdown>
						<button class="nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
							Le Club
							<i class="fas fa-chevron-down site-chevron"></i>
						</button>
						<div class="nav-dropdown-card" role="menu">
							<a class="nav-dropdown-link" href="{{ path('app_about') }}">Présentations du club</a>
							<a class="nav-dropdown-link" href="{{ path('app_evenement') }}">Événements</a>
							<a class="nav-dropdown-link" href="{{ path('app_actualites') }}">Actualités</a>
							<a class="nav-dropdown-link" href="{{ asset(get_document_path('PLANNING_COURS')|default('PlanningCours/PlanningCours.pdf')) }}" target="_blank">Planning des cours</a>
							<a class="nav-dropdown-link" href="{{ asset(get_document_path('PLANNING_COMPETITIONS')|default('PlanningCompetitions/PlanningCompetitions.pdf')) }}" target="_blank">Planning des compétitions</a>
							<a class="nav-dropdown-link" href="{{ path('app_resultats') }}">Résultats</a>
						</div>
					</div>

					<div class="site-dropdown" data-dropdown>
						<button class="nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
							Inscriptions
							<i class="fas fa-chevron-down site-chevron"></i>
						</button>
						<div class="nav-dropdown-card" role="menu">
							<a class="nav-dropdown-link" href="{{ path('app_inscription') }}">Inscriptions annuelles</a>
						</div>
					</div>

				</div>

				<a href="{{ path('home') }}"><img src="{{ asset('images/Logo_60ans.png') }}" alt="logo" class="site-logo"></a>

				<div class="nav-group-right">
					<div class="nav-link-group">
						<a class="nav-link-item" href="{{ path('album_show') }}">Galerie</a>
						<a class="nav-link-item" href="{{ path('app_boutique') }}">Boutique</a>
					</div>
				</div>
			</nav>

		</header>

		<!-- Header Mobile / Tablette -->
		<header class="site-header-mobile d-xl-none">
			<div class="mobile-navbar">
				<a href="{{ path('home') }}"><img src="{{ asset('images/Logo_60ans.png') }}" alt="logo" class="site-logo-mobile"></a>
				<div class="menu-btn" id="menu-toggle">
					<div class="menu-btn_burger"></div>
				</div>
			</div>
			
			<div class="mobile-menu-container" id="navbarNav">
				<nav class="mobile-nav" role="navigation" aria-label="Mobile navigation">
					<div class="nav-social-group justify-content-center mb-3">
						<a class="nav-social-btn nav-social-fb" href="https://www.facebook.com/angers.nat.synchro" target="_blank" title="Facebook" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
						<a class="nav-social-btn nav-social-ig" href="https://www.instagram.com/angers_nat_synchro/" target="_blank" title="Instagram" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
						<a class="nav-social-btn nav-social-tt" href="https://www.tiktok.com/@angersnatsynchro" target="_blank" title="TikTok" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
					</div>
					
					<div class="mobile-dropdown-group">
						<button class="nav-dropdown-toggle w-100 justify-content-between mobile-submenu-toggle">
							Le Club
							<i class="fas fa-chevron-down site-chevron"></i>
						</button>
						<div class="mobile-submenu">
							<a class="nav-dropdown-link" href="{{ path('app_about') }}">Présentations du club</a>
							<a class="nav-dropdown-link" href="{{ path('app_evenement') }}">Événements</a>
							<a class="nav-dropdown-link" href="{{ path('app_actualites') }}">Actualités</a>
							<a class="nav-dropdown-link" href="{{ asset(get_document_path('PLANNING_COURS')|default('PlanningCours/PlanningCours.pdf')) }}" target="_blank">Planning des cours</a>
							<a class="nav-dropdown-link" href="{{ asset(get_document_path('PLANNING_COMPETITIONS')|default('PlanningCompetitions/PlanningCompetitions.pdf')) }}" target="_blank">Planning des compétitions</a>
							<a class="nav-dropdown-link" href="{{ path('app_resultats') }}">Résultats</a>
						</div>
					</div>

					<div class="mobile-dropdown-group mt-2">
						<button class="nav-dropdown-toggle w-100 justify-content-between mobile-submenu-toggle">
							Inscriptions
							<i class="fas fa-chevron-down site-chevron"></i>
						</button>
						<div class="mobile-submenu">
							<a class="nav-dropdown-link" href="{{ path('app_inscription') }}">Inscriptions annuelles</a>
						</div>
					</div>

					<div class="nav-link-group flex-column mt-3 w-100" style="gap: 5px;">
						<a class="nav-link-item w-100 justify-content-center" href="{{ path('album_show') }}">Galerie</a>
						<a class="nav-link-item w-100 justify-content-center" href="{{ path('app_boutique') }}">Boutique</a>
					</div>
				</nav>
			</div>
		</header>
		{% block body %}{% endblock %}

		{% include 'partials/footer.html.twig' %}

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				// Burger Menu Logic
				const menuBtn = document.querySelector('.menu-btn');
				const navbar = document.getElementById('navbarNav');
				let menuOpen = false;
				
				if (menuBtn && navbar) {
					menuBtn.addEventListener('click', () => {
						if (!menuOpen) {
							menuBtn.classList.add('open');
							navbar.classList.add('show');
							menuOpen = true;
						} else {
							menuBtn.classList.remove('open');
							navbar.classList.remove('show');
							menuOpen = false;
						}
					});
				}

				// Mobile Submenu Logic
				const submenuToggles = document.querySelectorAll('.mobile-submenu-toggle');
				submenuToggles.forEach(toggle => {
					toggle.addEventListener('click', (e) => {
						const submenu = e.currentTarget.nextElementSibling;
						const icon = e.currentTarget.querySelector('.site-chevron');
						if (submenu.classList.contains('open')) {
							submenu.classList.remove('open');
							icon.style.transform = 'rotate(0deg)';
						} else {
							submenu.classList.add('open');
							icon.style.transform = 'rotate(180deg)';
						}
					});
				});
			});
		</script>

				</body>
			</html>
