{% extends 'admin_base.html.twig' %}
{% block title %}Gestion de la Page Inscription{% endblock %}
{% block page_title %}Page Inscription{% endblock %}
{% block body %}
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Contenu de la page Inscription</h2>
        {% if inscriptions|length == 0 %}
            <a href="{{ path('app_admin_inscription_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Créer le contenu</a>
        {% endif %}
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr><th>Permanences (aperçu)</th><th>Contact</th><th>Lien HelloAsso</th><th>Actions</th></tr>
            </thead>
            <tbody>
            {% for inscription in inscriptions %}
                <tr>
                    <td style="color: var(--text-muted);">{{ inscription.permanencesTexte|striptags|slice(0, 80) }}...</td>
                    <td>
                        <div style="font-weight: 500;">{{ inscription.contactNom }}</div>
                        <div style="color: var(--text-muted); font-size: 0.875rem;">{{ inscription.contactEmail }}</div>
                    </td>
                    <td style="color: var(--text-muted); font-size: 0.875rem;">{{ inscription.lienHelloasso|slice(0, 40) }}...</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="{{ path('app_admin_inscription_show', {'id': inscription.id}) }}" class="btn btn-sm btn-info" title="Voir"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_admin_inscription_edit', {'id': inscription.id}) }}" class="btn btn-sm btn-warning" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                            <form method="post" action="{{ path('app_admin_inscription_delete', {'id': inscription.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce contenu ?');" style="display: inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inscription.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; padding: 2rem;">
                        <div style="color: var(--text-muted); margin-bottom: 1rem;">
                            <i class="fa-solid fa-person-swimming" style="font-size: 2rem;"></i>
                            <p style="margin-top: 0.5rem;">Aucun contenu défini pour la page inscription.</p>
                        </div>
                        <a href="{{ path('app_admin_inscription_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Créer le contenu</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
